@page "{id:int}"
@using ChatR.Models.Constatns
@using ChatR.Models.Structure
@model ChatR.Pages.Users.ProfileModel
@{
    ViewData["Title"] = Model.UserToShow != null
        ? $"Профиль: {Model.UserToShow.FirstName} {Model.UserToShow.LastName}"
        : "Профиль";
}

<div class="container mt-4" style="max-width: 800px;">
    <h4 class="mb-4">Профиль пользователя</h4>

    @if (TempData[Messages.SUCCESS] != null)
    {
        <div class="alert alert-success">@TempData[Messages.SUCCESS]</div>
    }
    @if (TempData[Messages.ERROR] != null)
    {
        <div class="alert alert-danger">@TempData[Messages.ERROR]</div>
    }

    @if (Model.UserToShow == null)
    {
        <div class="alert alert-danger">Пользователь не найден.</div>
    }
    else
    {
        <!-- Карточка профиля -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                @if (Model.IsOwnProfile)
                {
                    <h5 class="card-title text-primary border-bottom pb-2 mb-3">
                        Личная информация
                    </h5>
                }
                else
                {
                    <h5 class="card-title text-primary border-bottom pb-2 mb-3">
                        Информация о пользователе
                    </h5>
                }

                <!-- Таблица информации -->
                <dl class="row mb-0">
                    <dt class="col-sm-3 fw-bold text-muted">Фамилия</dt>
                    <dd class="col-sm-9">@Model.UserToShow.LastName</dd>

                    <dt class="col-sm-3 fw-bold text-muted">Имя</dt>
                    <dd class="col-sm-9">@Model.UserToShow.FirstName</dd>

                    <dt class="col-sm-3 fw-bold text-muted">Отчество</dt>
                    <dd class="col-sm-9">@(Model.UserToShow.Patronymic ?? "-")</dd>

                    <dt class="col-sm-3 fw-bold text-muted">Email</dt>
                    <dd class="col-sm-9">@Model.UserToShow.Email</dd>

                    <dt class="col-sm-3 fw-bold text-muted">Дата регистрации</dt>
                    <dd class="col-sm-9">@Model.UserToShow.CreatedAt.ToString("dd.MM.yyyy")</dd>
                </dl>
            </div>
        </div>

        <!-- Кнопка редактирования (только для своего профиля) -->
        @if (Model.IsOwnProfile)
        {
            <button type="button" class="btn btn-outline-primary mb-4" id="editButton">
                Редактировать
            </button>
        }

        <!-- Форма редактирования (изначально скрыта) -->
        <div id="editMode" class="d-none">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Редактирование профиля</h6>
                </div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label">Имя</label>
                                <input asp-for="FirstName" class="form-control" required />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label">Фамилия</label>
                                <input asp-for="LastName" class="form-control" required />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Patronymic" class="form-label">Отчество</label>
                                <input asp-for="Patronymic" class="form-control" />
                                <span asp-validation-for="Patronymic" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label for="Password" class="form-label">Новый пароль (оставьте пустым, чтобы не менять)</label>
                                <input id="Password"
                                       name="Password"
                                       type="password"
                                       class="form-control"
                                       minlength="6"
                                       placeholder="••••••" />
                                <div class="form-text">Минимум 6 символов</div>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-success">Сохранить</button>
                            <button type="button" class="btn btn-secondary" id="cancelEdit">Отмена</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Удаление аккаунта -->
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h6 class="text-danger">Удаление аккаунта</h6>
                    <p class="text-muted small">Это действие нельзя отменить. Все ваши сообщения останутся, но аккаунт будет удалён.</p>
                    <form method="post" asp-page-handler="Delete">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Вы уверены, что хотите удалить аккаунт? Это действие нельзя отменить.')">
                            Удалить аккаунт
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        const viewMode = document.querySelector(".card"); // Основная карточка
        const editMode = document.getElementById("editMode");
        const editButton = document.getElementById("editButton");
        const cancelEdit = document.getElementById("cancelEdit");

        editButton?.addEventListener("click", () => {
            viewMode.classList.add("d-none");
            editButton.classList.add("d-none");

            editMode.classList.remove("d-none");
        });

        cancelEdit?.addEventListener("click", () => {
            viewMode.classList.remove("d-none");
            editButton.classList.remove("d-none");

            editMode.classList.add("d-none");
        });
    </script>
}