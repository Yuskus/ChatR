@page "{id:int}"
@using ChatR.Models.Constatns
@using ChatR.Models.Structure
@model ChatR.Pages.Users.ProfileModel
@{
    ViewData["Title"] = Model.UserToShow != null
        ? $"Профиль: {Model.UserToShow.FirstName} {Model.UserToShow.LastName}"
        : "Профиль";
}

<div class="container mt-4 profile-block">
    <h4 class="mb-4">Профиль пользователя</h4>

    @if (TempData[Messages.SUCCESS] != null)
    {
        <div class="alert alert-success">@TempData[Messages.SUCCESS]</div>
    }
    @if (TempData[Messages.ERROR] != null)
    {
        <div class="alert alert-danger">@TempData[Messages.ERROR]</div>
    }

    @if (Model.UserToShow == null)
    {
        <div class="alert alert-danger">Пользователь не найден.</div>
    }
    else
    {
        <!-- Карточка профиля -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    @if (Model.IsOwnProfile)
                    {
                        <h5 class="card-title text-primary border-bottom pb-2 mb-3 m-0">
                            Личная информация
                        </h5>
                        <a href="@Routes.Pages.Users.EditProfile" class="btn btn-sm btn-outline-primary">
                            ✏️
                        </a>
                    }
                    else
                    {
                        <h5 class="card-title text-primary border-bottom pb-2 mb-3">
                            Информация о пользователе
                        </h5>
                    }
                </div>

                <!-- Таблица информации -->
                <dl class="row mb-0">
                    <dt class="col-sm-4 fw-bold text-muted">Фамилия</dt>
                    <dd class="col-sm-8">@Model.UserToShow.LastName</dd>

                    <dt class="col-sm-4 fw-bold text-muted">Имя</dt>
                    <dd class="col-sm-8">@Model.UserToShow.FirstName</dd>

                    <dt class="col-sm-4 fw-bold text-muted">Отчество</dt>
                    <dd class="col-sm-8">@(Model.UserToShow.Patronymic ?? "-")</dd>
                    
                    <dt class="col-sm-4 fw-bold text-muted">Дата регистрации</dt>
                    <dd class="col-sm-8">@Model.UserToShow.CreatedAt.ToString("dd.MM.yyyy")</dd>

                    <dt class="col-sm-4 fw-bold text-muted">Дата последнего входа:</dt>
                    <dd class="col-sm-8">@(Model.UserToShow.LastLogin?.ToString("dd.MM.yyyy") ?? "-")</dd>
                </dl>
            </div>
        </div>

        <!-- Кнопки подписки и навигации (для всех профилей) -->
        <div class="mb-3">
            <a href="@Routes.Pages.Observings.UsersFrom/@Model.UserToShow.Id" class="btn btn-outline-success btn-sm me-2">
                Подписки (@(Model.UsersFromCount))
            </a>
            <a href="@Routes.Pages.Observings.UsersTo/@Model.UserToShow.Id" class="btn btn-outline-info btn-sm">
                Подписчики (@(Model.UsersToCount))
            </a>
        </div>

        <!-- Кнопки подписки (только для чужих профилей) -->
        @if (!Model.IsOwnProfile)
        {
            <div class="mb-3">
                @if (Model.IsSubscribed)
                {
                    <form method="post" asp-page-handler="Unsubscribe">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            Отписаться
                        </button>
                    </form>
                }
                else
                {
                    <form method="post" asp-page-handler="Subscribe">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">
                            Подписаться
                        </button>
                    </form>
                }
            </div>
        }
    }
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
