@page "{userId:int}"
@using ChatR.Models.Constatns
@using ChatR.Models.Structure
@model ChatR.Pages.Observings.UsersToModel
@{
    ViewData["Title"] = "Подписчики";
}

<div class="container mt-4">
    <h4 class="mb-4">Подписчики пользователя (@Model.UsersToCount)</h4>

    @if (TempData[Messages.SUCCESS] != null)
    {
        <div class="alert alert-success">@TempData[Messages.SUCCESS]</div>
    }
    @if (TempData[Messages.ERROR] != null)
    {
        <div class="alert alert-danger">@TempData[Messages.ERROR]</div>
    }

    @if (Model.Observings == null || !Model.Observings.Any())
    {
        <div class="alert alert-info">У пользователя пока нет подписчиков.</div>
    }
    else
    {
        <div class="row">
            @foreach (var observing in Model.Observings)
            {
                var user = observing.UserFrom;
                if (user == null) continue;

                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="card-title">@user.LastName @user.FirstName @user.Patronymic</h6>
                            <p class="card-text text-muted small">Подписался: @observing.CreatedAt.ToString("dd.MM.yyyy")</p>
                            <a href="@Routes.Pages.Users.Profile/@user.Id" class="btn btn-outline-primary btn-sm">
                                Перейти к профилю
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
