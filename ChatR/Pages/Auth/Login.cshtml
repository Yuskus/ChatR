@page
@model ChatR.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="container mt-5" style="max-width: 400px;">
    <h3 class="text-center mb-4">Вход в чат</h3>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email"
                   class="form-control"
                   id="email"
                   asp-for="Email"
                   placeholder="Введите email"
                   required />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">Пароль</label>
            <input type="password"
                   class="form-control"
                   id="password"
                   asp-for="Password"
                   placeholder="Введите пароль"
                   required />
        </div>

        <button type="submit" class="btn btn-primary w-100">Войти</button>
    </form>

    <div class="text-center mt-3">
        <p>Нет аккаунта? <a asp-page="/Auth/Register">Зарегистрироваться</a></p>
    </div>
</div>