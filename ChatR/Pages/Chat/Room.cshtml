@page
@using ChatR.Models.Structure
@model ChatR.Pages.Chat.RoomModel
@{
    ViewData["Title"] = $"Чат: {Model.RoomName}";
}

<div class="container-fluid message-container">
    <h4>
        <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#participantsModal">
            @Model.RoomName
        </button>
    </h4>

    <!-- Модальное окно для участников -->
    <div class="modal fade" id="participantsModal" tabindex="-1" aria-labelledby="participantsModalLabel" aria-hidden="false">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="participantsModalLabel">Участники (@Model.RoomUsers.Count)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <ul class="list-group">
                        @foreach (var user in Model.RoomUsers)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>
                                        <a href="@Routes.Pages.Users.Profile/@user.Id" class="text-decoration-none">
                                            @user.FirstName @user.LastName
                                        </a>
                                    </strong>
                                    <small class="text-muted"> (@user.Email)</small>
                                </div>
                                <span class="badge bg-primary rounded-pill">@(user.Id == Model.CurrentUserId ? "Вы" : "")</span>
                            </li>
                        }
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Комната чата</span>
            <a asp-page="@Routes.Pages.Index" class="btn btn-sm btn-outline-secondary">← Назад</a>
        </div>
        <div class="card-body p-0">
            <ul id="messagesList"
                class="list-group list-group-flush message-list"
                data-current-user-id="@Model.CurrentUserId"
                data-room-id="@Model.RoomId"
                data-group-name="chat_@Model.RoomId">

                @* Рендерим сообщения сразу на сервере *@
                @foreach (var msg in Model.Messages)
                {
                    <li class="list-group-item border-0" data-message-id="@msg.Id">
                        <strong>
                            <a href="@Routes.Pages.Users.Profile/@msg.UserId" class="text-decoration-none">
                                @msg.User?.FirstName @msg.User?.LastName
                            </a>
                        </strong>
                        <small class="text-muted">[@msg.Timestamp.ToString("dd.MM.yyyy HH:mm")]</small>

                        <div class="multiline-text">@msg.Content</div>
                        @if (msg.UserId == Model.CurrentUserId)
                        {
                            <div class="mt-1">
                                <button class="btn btn-sm btn-warning edit-btn"
                                        data-id="@msg.Id"
                                        data-content="@msg.Content">
                                    Редактировать
                                </button>
                                <button class="btn btn-sm btn-danger delete-btn" data-id="@msg.Id">Удалить</button>
                            </div>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>

    <!-- Форма отправки -->
    <div class="input-group mb-3">
        <textarea id="messageInput"
                class="form-control message-field"
                placeholder="Введите сообщение..."
                maxlength="5000"
                rows="1"
                data-min-rows="1"
                data-max-rows="3"></textarea>
        <button id="sendButton"
                class="btn btn-primary"
                title="Нажмите и удерживайте, чтобы выбрать способ отправки"
                disabled>Отправить</button>
    </div>

    <!-- Редактирование -->
    <div id="editForm" class="input-group mb-3 d-none">
        <input type="hidden" id="editMessageId" />
        <textarea id="editMessageInput"
                class="form-control message-field"
                maxlength="5000"
                rows="1"
                data-min-rows="1"
                data-max-rows="3"></textarea>
        <button id="saveEditButton" class="btn btn-success">Сохранить</button>
        <button id="cancelEditButton" class="btn btn-secondary">Отмена</button>
    </div>
</div>

@section Scripts
{
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/chat/room.js"></script>
}